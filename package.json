{
  "name": "web-battle-royale-fps",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "engines": {
    "node": ">=24"
  },
  "scripts": {
    "dev": "vite --host 127.0.0.1",
    "dev:worker": "wrangler dev --config wrangler.worker.jsonc --ip 127.0.0.1 --port 8787",
    "dev:server": "node --env-file-if-exists=.env.standalone --watch --import tsx standalone/index.ts",
    "deploy:worker": "npm run typecheck:worker && npm run test:worker && npm run build:worker && wrangler deploy --config wrangler.worker.jsonc && npm run test:multiplayer:production",
    "build": "tsc -b && vite build",
    "build:worker": "wrangler deploy --config wrangler.worker.jsonc --dry-run --outdir dist-worker",
    "build:server": "tsc -p tsconfig.server.json --pretty false && esbuild standalone/index.ts --bundle --platform=node --format=esm --target=node24 --external:ws --outfile=dist-server/server.js",
    "build:standalone": "VITE_MULTIPLAYER_ENABLED=true VITE_MULTIPLAYER_URL=same-origin npm run build && npm run build:server",
    "check:budgets": "node scripts/check-performance-budgets.mjs",
    "start:server": "node --env-file-if-exists=.env.standalone dist-server/server.js",
    "types:worker": "wrangler types types/worker-configuration.d.ts --config wrangler.worker.jsonc",
    "typecheck:app": "tsc -b --pretty false",
    "typecheck:worker": "tsc -p tsconfig.worker.json --pretty false && tsc -p tsconfig.worker-tests.json --pretty false",
    "typecheck:server": "tsc -p tsconfig.server.json --pretty false",
    "typecheck": "npm run typecheck:app && npm run typecheck:worker && npm run typecheck:server",
    "test:unit": "vitest run --config config/vitest/unit.config.ts",
    "test:worker": "vitest run --config config/vitest/worker.config.ts --max-workers=1 --no-isolate",
    "test:server": "vitest run --config config/vitest/standalone.config.ts --max-workers=1",
    "test": "npm run test:unit && npm run test:worker && npm run test:server",
    "test:multiplayer:production": "tsx scripts/smoke-production-multiplayer.ts",
    "test:coverage:unit": "vitest run --config config/vitest/unit.config.ts --coverage",
    "test:coverage:worker": "vitest run --config config/vitest/worker.config.ts --max-workers=1 --no-isolate --coverage",
    "test:coverage:server": "vitest run --config config/vitest/standalone.config.ts --max-workers=1 --coverage",
    "test:coverage": "npm run test:coverage:unit && npm run test:coverage:worker && npm run test:coverage:server && tsx scripts/report-coverage-baseline.ts",
    "test:watch": "vitest --config config/vitest/unit.config.ts",
    "preview": "vite preview --host 127.0.0.1"
  },
  "dependencies": {
    "@babylonjs/core": "^9.16.2",
    "@babylonjs/loaders": "^9.16.2",
    "ws": "^8.21.1"
  },
  "devDependencies": {
    "@cloudflare/vitest-pool-workers": "^0.18.6",
    "@types/node": "^24.13.3",
    "@types/ws": "^8.18.1",
    "@vitest/coverage-istanbul": "4.1.10",
    "@vitest/coverage-v8": "4.1.10",
    "esbuild": "^0.28.1",
    "tsx": "^4.23.1",
    "typescript": "^7.0.2",
    "vite": "^8.1.4",
    "vitest": "^4.1.10",
    "wrangler": "^4.112.0"
  }
}
