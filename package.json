{
  "name": "web-battle-royale-fps",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "engines": {
    "node": ">=24"
  },
  "scripts": {
    "dev": "vite --host 127.0.0.1",
    "dev:worker": "wrangler dev --config wrangler.worker.jsonc --ip 127.0.0.1 --port 8787",
    "deploy:worker": "wrangler deploy --config wrangler.worker.jsonc",
    "build": "tsc -b && vite build",
    "build:worker": "wrangler deploy --config wrangler.worker.jsonc --dry-run --outdir dist-worker",
    "types:worker": "wrangler types --config wrangler.worker.jsonc",
    "typecheck:app": "tsc -b --pretty false",
    "typecheck:worker": "tsc -p tsconfig.worker.json --pretty false && tsc -p tsconfig.worker-tests.json --pretty false",
    "typecheck": "npm run typecheck:app && npm run typecheck:worker",
    "test:unit": "vitest run --config vitest.config.ts",
    "test:worker": "vitest run --config vitest.worker.config.ts --max-workers=1 --no-isolate",
    "test": "npm run test:unit && npm run test:worker",
    "test:watch": "vitest",
    "preview": "vite preview --host 127.0.0.1"
  },
  "dependencies": {
    "@babylonjs/core": "^9.16.2",
    "@babylonjs/loaders": "^9.16.2"
  },
  "devDependencies": {
    "@cloudflare/vitest-pool-workers": "^0.18.6",
    "typescript": "^7.0.2",
    "vite": "^8.1.4",
    "vitest": "^4.1.10",
    "wrangler": "^4.112.0"
  }
}
